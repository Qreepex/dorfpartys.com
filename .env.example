# --- Datenbank ---
DATABASE_URL=postgresql://dorfpartys:dorfpartys@localhost:5433/dorfpartys

# --- Authentik (OpenID Connect) ---
# Issuer-URL deiner Authentik-Instanz, z.B. https://auth.dorfpartys.com/application/o/dorfpartys/
AUTHENTIK_ISSUER=https://auth.dorfpartys.com/application/o/dorf-partys-com/
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
# JWKS-Endpoint für die zustandslose JWT-Verifizierung im Backend
AUTHENTIK_JWKS_URL=https://auth.dorfpartys.com/application/o/dorf-partys-com/jwks/
# Redirect-URI, auf die Authentik nach Login zurückleitet (Frontend-Route)
AUTHENTIK_REDIRECT_URI=http://dorfpartys.localhost:5173/auth/callback
# Authentik-Gruppennamen -> App-Rollen (JWT "groups"-Claim enthält Gruppen-NAMEN, keine IDs,
# siehe backend/src/auth/roles.ts). Gruppen in Authentik:
#   Dorfpartys.com - Admin      (Gruppen-ID 4e4f3f40-20ce-4492-b0d9-5e908597f3da)
#   Dorfpartys.com - Moderator  (Gruppen-ID 182f4f89-8e94-435a-aaef-2c28cf0952b9)
AUTHENTIK_ADMIN_GROUP="Dorfpartys.com - Admin"
AUTHENTIK_MODERATOR_GROUP="Dorfpartys.com - Moderator"

# --- Session ---
SESSION_COOKIE_SECRET=

# --- IONOS S3 (speicher.dorfpartys.com) ---
S3_ENDPOINT=https://speicher.dorfpartys.com
S3_REGION=eu-central-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Backend ---
PORT=3033
NODE_ENV=development

# --- Frontend ---
PUBLIC_SITE_URL=https://www.dorfpartys.com
# Interne K8s-Service-DNS-Adresse des Backends (nicht die öffentliche Domain, siehe AGENTS.md 0)
BACKEND_INTERNAL_URL=http://127.0.0.1:3033
