# Nur nötig für Quellen, die einen API-Key brauchen (siehe README "Neue Quelle
# hinzufügen"). Die Standard-Quellen in sources.ts brauchen keinen Key.
# OEW_API_KEY=
#
# Basis-URL deiner OpenWebUI-Instanz, ohne trailing slash, z.B. https://ai.example.com
# OPENWEBUI_BASE_URL=
# API-Key aus OpenWebUI: Einstellungen -> Konto -> API-Keys
# OPENWEBUI_API_KEY=
# Name/ID des zu nutzenden Modells, wie in OpenWebUI hinterlegt
# OPENWEBUI_MODEL=
