{
  "name": "@dorfpartys/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && node scripts/copy-migrations.mjs",
    "start": "node dist/index.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=.env src/db/migrate.ts",
    "db:seed": "tsx src/db/seed/index.ts",
    "db:seed:demo": "tsx src/db/seed/demo-events.ts",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@dorfpartys/shared": "workspace:*",
    "@fastify/cookie": "^11.1.2",
    "@fastify/cors": "^11.3.0",
    "@trpc/server": "^11.0.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.10.0",
    "file-type": "^18.7.0",
    "jose": "^6.2.3",
    "nodemailer": "^9.0.3",
    "postgres": "^3.4.9",
    "sharp": "^0.35.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "*",
    "@types/nodemailer": "^8.0.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^3.0.0"
  }
}
