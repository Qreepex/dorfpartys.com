{
  "name": "dorfpartys.com",
  "version": "1.0.0",
  "private": true,
  "description": "dorfpartys.com",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm run --parallel --filter ./frontend --filter ./backend dev",
    "dev:frontend": "pnpm --filter ./frontend dev",
    "dev:backend": "pnpm --filter ./backend dev",
    "build": "pnpm --filter ./shared build && pnpm --filter ./backend build && pnpm --filter ./frontend build",
    "build:shared": "pnpm --filter ./shared build",
    "db:generate": "pnpm --filter ./backend db:generate",
    "db:migrate": "pnpm --filter ./backend db:migrate",
    "db:seed": "pnpm --filter ./backend db:seed",
    "lint": "pnpm --filter ./frontend lint",
    "format": "pnpm --filter ./frontend format",
    "check": "pnpm --filter ./shared check && pnpm --filter ./backend check && pnpm --filter ./frontend check && pnpm --filter ./ingestion check",
    "test": "pnpm --filter ./backend test",
    "ingest": "pnpm --filter ./ingestion start",
    "watch-urls": "pnpm --filter ./ingestion watch-urls",
    "import:csv": "pnpm --filter ./backend import:csv"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Qreepex/dorfpartys.com.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Qreepex/dorfpartys.com/issues"
  },
  "homepage": "https://github.com/Qreepex/dorfpartys.com#readme",
  "devDependencies": {
    "typescript": "^7.0.2"
  }
}
