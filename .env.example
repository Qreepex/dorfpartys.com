# --- Datenbank ---
DATABASE_URL=postgresql://dorfpartys:dorfpartys@localhost:5432/dorfpartys

# --- Authentik (OpenID Connect) ---
# Issuer-URL deiner Authentik-Instanz, z.B. https://auth.dorfpartys.com/application/o/dorfpartys/
AUTHENTIK_ISSUER=
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
# JWKS-Endpoint für die zustandslose JWT-Verifizierung im Backend
AUTHENTIK_JWKS_URL=
# Redirect-URI, auf die Authentik nach Login zurückleitet (Frontend-Route)
AUTHENTIK_REDIRECT_URI=http://localhost:5173/auth/callback
# Authentik-Gruppennamen -> App-Rollen (offener Punkt, siehe AGENTS.md 10)
AUTHENTIK_ADMIN_GROUP=admin
AUTHENTIK_MODERATOR_GROUP=moderator

# --- Session ---
SESSION_COOKIE_SECRET=

# --- IONOS S3 (speicher.dorfpartys.com) ---
S3_ENDPOINT=https://speicher.dorfpartys.com
S3_REGION=eu-central-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Backend ---
PORT=3000
NODE_ENV=development

# --- Frontend ---
PUBLIC_SITE_URL=https://dorfpartys.com
# Interne K8s-Service-DNS-Adresse des Backends (nicht die öffentliche Domain, siehe AGENTS.md 0)
BACKEND_INTERNAL_URL=http://backend:3000
