{
	"name": "@dorfpartys/backend",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"main": "./dist/index.js",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc -p tsconfig.json",
		"start": "node dist/index.js",
		"check": "tsc -p tsconfig.json --noEmit",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "tsx src/db/migrate.ts",
		"db:studio": "drizzle-kit studio"
	},
	"dependencies": {
		"@dorfpartys/shared": "*",
		"@fastify/cookie": "^11.1.2",
		"@fastify/cors": "^11.3.0",
		"bcryptjs": "^3.0.3",
		"drizzle-orm": "^0.45.2",
		"fastify": "^5.10.0",
		"jose": "^6.2.3",
		"postgres": "^3.4.9",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@types/node": "*",
		"drizzle-kit": "^0.31.10",
		"tsx": "^4.23.1",
		"typescript": "^7.0.2"
	}
}
